{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sutemi",
  "version": "0.5.0",
  "identifier": "com.sutemi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sutemi",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop GUI for Jujutsu",
    "longDescription": "A Tauri + Vue desktop interface for inspecting Jujutsu repositories with a native command bridge."
  }
}
